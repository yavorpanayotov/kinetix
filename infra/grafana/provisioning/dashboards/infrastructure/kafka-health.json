{
  "uid": "kinetix-kafka-health",
  "title": "Kafka Health",
  "tags": ["kinetix", "infrastructure", "kafka"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    { "title": "System Health", "type": "link", "url": "/d/kinetix-system-health", "icon": "dashboard" },
    { "title": "Service Overview", "type": "link", "url": "/d/kinetix-service-overview", "icon": "dashboard" },
    { "title": "Trade Flow", "type": "link", "url": "/d/kinetix-trade-flow", "icon": "dashboard" },
    { "title": "Risk Overview", "type": "link", "url": "/d/kinetix-risk-overview", "icon": "dashboard" },
    { "title": "Risk Engine", "type": "link", "url": "/d/kinetix-risk-engine", "icon": "dashboard" },
    { "title": "Risk Orchestrator", "type": "link", "url": "/d/kinetix-risk-orchestrator", "icon": "dashboard" },
    { "title": "Price", "type": "link", "url": "/d/kinetix-prices", "icon": "dashboard" },
    { "title": "Database Health", "type": "link", "url": "/d/kinetix-database-health", "icon": "dashboard" },
    { "title": "Service Logs", "type": "link", "url": "/d/kinetix-service-logs", "icon": "dashboard" }
  ],
  "panels": [
    {
      "title": "Consumer Group Lag",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "kafka_consumergroup_lag",
          "legendFormat": "{{consumergroup}} / {{topic}} [{{partition}}]"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "Messages In Per Second",
      "type": "timeseries",
      "description": "Partition-offset-derived throughput estimate. The only Kafka scrape target is kafka-exporter (no broker JMX target), so there is no native broker messages-in-per-sec metric. This is the conventional proxy: the rate of change of partition end offsets approximates produce throughput per topic.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (topic) (rate(kafka_topic_partition_current_offset[5m]))",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "title": "Topic Partition Count",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "count by (topic) (kafka_topic_partitions)",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "noValue": "No data" },
        "overrides": []
      }
    },
    {
      "title": "Under-Replicated Partitions",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "sum(kafka_topic_partition_under_replicated_partition)",
          "legendFormat": "Under-replicated"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "No data",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Broker Count",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "count(kafka_brokers)",
          "legendFormat": "Brokers"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "noValue": "No data" },
        "overrides": []
      }
    },
    {
      "title": "DLQ Depth",
      "type": "timeseries",
      "description": "Absolute message count sitting in each dead-letter topic, derived from partition end offsets. A rate-based panel reads zero for a stalled (non-growing) DLQ and looks healthy; absolute depth stays visibly non-zero while messages remain unprocessed. Any non-zero value is a problem — red threshold at 1.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (topic) (kafka_topic_partition_current_offset{topic=~\".*\\.dlq\"})",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "custom": {
            "thresholdsStyle": { "mode": "line" }
          }
        },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  }
}
