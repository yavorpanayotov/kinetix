{
  "uid": "kinetix-position-concentration",
  "title": "Position Concentration",
  "tags": ["kinetix", "trading", "positions"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "links": [
    { "title": "P&L", "type": "link", "url": "/d/kinetix-pnl", "icon": "dashboard" },
    { "title": "Trade Flow", "type": "link", "url": "/d/kinetix-trade-flow", "icon": "dashboard" },
    { "title": "Risk Overview", "type": "link", "url": "/d/kinetix-risk-overview?var-book_id=${book_id}", "icon": "dashboard" },
    { "title": "Service Logs", "type": "link", "url": "/d/kinetix-service-logs", "icon": "dashboard" }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Data source",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "regex": "",
        "options": []
      },
      {
        "name": "book_id",
        "type": "query",
        "label": "Book",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(position_notional, book_id)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" },
        "multi": true,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Net Exposure",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(position_notional{book_id=~\"$book_id\", side=\"LONG\"}) - sum(position_notional{book_id=~\"$book_id\", side=\"SHORT\"})",
          "legendFormat": "Net exposure"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "noValue": "No data",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Long Exposure",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(position_notional{book_id=~\"$book_id\", side=\"LONG\"})",
          "legendFormat": "Long"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "noValue": "No data",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Short Exposure",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(position_notional{book_id=~\"$book_id\", side=\"SHORT\"})",
          "legendFormat": "Short"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "noValue": "No data",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Open Positions",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(position_count{book_id=~\"$book_id\"})",
          "legendFormat": "Open positions"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "No data",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Long / Short Split",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (side) (position_notional{book_id=~\"$book_id\"})",
          "legendFormat": "{{side}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "stacking": { "mode": "none" }
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Net Exposure Trend",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(position_notional{book_id=~\"$book_id\", side=\"LONG\"}) - sum(position_notional{book_id=~\"$book_id\", side=\"SHORT\"})",
          "legendFormat": "Net exposure"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 0 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Top 10 Concentrations by Instrument",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 17 },
      "targets": [
        {
          "expr": "topk(10, sum by (instrument_id) (position_notional{book_id=~\"$book_id\"}))",
          "legendFormat": "{{instrument_id}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "noValue": "No data",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000000 },
              { "color": "red", "value": 5000000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },
    {
      "id": 8,
      "title": "Top 10 Concentrations by Book",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 17 },
      "targets": [
        {
          "expr": "topk(10, sum by (book_id) (position_notional{book_id=~\"$book_id\"}))",
          "legendFormat": "{{book_id}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "noValue": "No data",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000000 },
              { "color": "red", "value": 20000000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },
    {
      "id": 9,
      "title": "Open Positions by Book",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "targets": [
        {
          "expr": "position_count{book_id=~\"$book_id\"}",
          "legendFormat": "{{book_id}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "No data",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
