{
  "uid": "kinetix-fix-gateway-overview",
  "title": "FIX Gateway Overview",
  "tags": ["kinetix", "trading", "fix-gateway", "execution"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "links": [
    { "title": "System Health", "type": "link", "url": "/d/kinetix-system-health", "icon": "dashboard" },
    { "title": "Trade Flow", "type": "link", "url": "/d/kinetix-trade-flow", "icon": "dashboard" },
    { "title": "Service Logs", "type": "link", "url": "/d/kinetix-service-logs", "icon": "dashboard" }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Data source",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "regex": "",
        "options": []
      }
    ]
  },
  "panels": [
    {
      "title": "FIX Session State (per venue)",
      "description": "Logon state of each FIX session. Uses the 'last' reducer (not 'lastNotNull') so that when the FIX gateway stops being scraped the panel renders 'No data' rather than holding the last UP sample green indefinitely.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "fix_session_state",
          "legendFormat": "{{venue}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "No data",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["last"] }
      }
    },
    {
      "title": "Inbound Messages / sec (by venue + msg_type)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum by (venue, msg_type) (rate(fix_messages_in_total[5m]))",
          "legendFormat": "{{venue}} / {{msg_type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "title": "Outbound Messages / sec (by venue + msg_type)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "sum by (venue, msg_type) (rate(fix_messages_out_total[5m]))",
          "legendFormat": "{{venue}} / {{msg_type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "title": "Cancel Ack Latency p50 / p95 / p99 (by venue)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (venue, le) (rate(cancel_ack_latency_seconds_bucket[5m])))",
          "legendFormat": "{{venue}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (venue, le) (rate(cancel_ack_latency_seconds_bucket[5m])))",
          "legendFormat": "{{venue}} p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (venue, le) (rate(cancel_ack_latency_seconds_bucket[5m])))",
          "legendFormat": "{{venue}} p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 5,
      "title": "Ghost Fill Detection",
      "type": "text",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 22 },
      "options": {
        "mode": "markdown",
        "content": "⚠️ **Not yet instrumented.** Ghost-fill detection is not implemented in `fix-gateway`. This panel is a placeholder; no `ghost_fill_detected_total` metric is emitted. Building ghost-fill detection is tracked as separate product work."
      }
    },
    {
      "title": "Cancel Attempts by Outcome (rate, by venue)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 22 },
      "targets": [
        {
          "expr": "sum by (venue, reason) (rate(cancel_failed_total[5m]))",
          "legendFormat": "{{venue}} / {{reason}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "title": "Unacknowledged Outbound (counter, by venue)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 22 },
      "targets": [
        {
          "expr": "sum by (venue, msg_type) (unacknowledged_outbound)",
          "legendFormat": "{{venue}} / {{msg_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "No data",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "PendingNewCorrelator: TTL Evictions (rate, by venue)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "sum by (venue) (rate(pending_new_correlator_ttl_evictions_total[5m]))",
          "legendFormat": "{{venue}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "title": "PendingNewCorrelator: Back-Pressure (rate, by venue)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "sum by (venue) (rate(pending_new_correlator_back_pressure_total[5m]))",
          "legendFormat": "{{venue}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "title": "Session Reconciliation Outcomes (post-reconnect 35=H sweep)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 36 },
      "targets": [
        {
          "expr": "sum by (venue, outcome) (rate(fix_session_reconciliation_total[5m]))",
          "legendFormat": "{{venue}} / {{outcome}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 11,
      "title": "FIX Log Partitions Archived",
      "type": "text",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 44 },
      "options": {
        "mode": "markdown",
        "content": "⚠️ **Not yet instrumented.** FIX message-log partition archival is not implemented in `fix-gateway`. This panel is a placeholder; no `fix_message_log_partitions_archived_total` metric is emitted. Adding partition-archival to the FIX message log is tracked as separate product work."
      }
    },
    {
      "id": 12,
      "title": "mTLS Handshake Failures",
      "type": "text",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 44 },
      "options": {
        "mode": "markdown",
        "content": "⚠️ **Not yet instrumented.** mTLS handshake monitoring is not implemented in `fix-gateway`. This panel is a placeholder; no `mtls_handshake_failed_total` metric is emitted. Adding mTLS handshake instrumentation is tracked as separate product work."
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
