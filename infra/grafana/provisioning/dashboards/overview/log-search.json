{
  "uid": "kinetix-log-search",
  "title": "Log Search",
  "tags": ["kinetix", "logs", "overview", "search"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "links": [
    { "title": "Service Logs", "type": "link", "url": "/d/kinetix-service-logs", "icon": "dashboard" },
    { "title": "System Health", "type": "link", "url": "/d/kinetix-system-health", "icon": "dashboard" },
    { "title": "Service Overview", "type": "link", "url": "/d/kinetix-service-overview", "icon": "dashboard" }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Data source",
        "query": "loki",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "regex": "",
        "options": []
      },
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": { "type": "loki", "uid": "${datasource}" },
        "query": "label_values(service_name)",
        "includeAll": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" },
        "multi": true,
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "level",
        "type": "custom",
        "label": "Level",
        "query": "ERROR,WARN,INFO,DEBUG,TRACE",
        "includeAll": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" },
        "multi": true,
        "hide": 0
      },
      {
        "name": "search",
        "type": "textbox",
        "label": "Free text",
        "description": "Substring match against the log line (LogQL |= filter). Leave empty to match all.",
        "query": "",
        "current": { "text": "", "value": "" },
        "hide": 0
      },
      {
        "name": "correlationId",
        "type": "textbox",
        "label": "Correlation ID",
        "description": "Filter by the correlationId structured-metadata field. Leave as .* to match all.",
        "query": ".*",
        "current": { "text": ".*", "value": ".*" },
        "hide": 0
      },
      {
        "name": "userId",
        "type": "textbox",
        "label": "User ID",
        "description": "Filter by the userId structured-metadata field. Leave as .* to match all.",
        "query": ".*",
        "current": { "text": ".*", "value": ".*" },
        "hide": 0
      },
      {
        "name": "endpoint",
        "type": "textbox",
        "label": "Endpoint",
        "description": "Filter by the HTTP endpoint (request path) structured-metadata field. Leave as .* to match all.",
        "query": ".*",
        "current": { "text": ".*", "value": ".*" },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Log Volume by Level",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 18, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (detected_level) (count_over_time({service_name=~\"$service\"} | correlationId=~\"$correlationId\" | userId=~\"$userId\" | endpoint=~\"$endpoint\" |= \"$search\" [$__auto]))",
          "legendFormat": "{{detected_level}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": { "mode": "normal" },
            "fillOpacity": 80
          },
          "unit": "short"
        }
      },
      "options": {
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 2,
      "title": "Errors",
      "type": "stat",
      "gridPos": { "h": 7, "w": 3, "x": 18, "y": 0 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=~\"$service\"} | detected_level=`ERROR` | correlationId=~\"$correlationId\" | userId=~\"$userId\" | endpoint=~\"$endpoint\" |= \"$search\" [$__range]))",
          "legendFormat": "Errors",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Warnings",
      "type": "stat",
      "gridPos": { "h": 7, "w": 3, "x": 21, "y": 0 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=~\"$service\"} | detected_level=`WARN` | correlationId=~\"$correlationId\" | userId=~\"$userId\" | endpoint=~\"$endpoint\" |= \"$search\" [$__range]))",
          "legendFormat": "Warnings",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Log Lines",
      "type": "logs",
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 7 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "{service_name=~\"$service\"} | detected_level=~\"$level\" | correlationId=~\"$correlationId\" | userId=~\"$userId\" | endpoint=~\"$endpoint\" |= \"$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
