{
  "uid": "kinetix-notification-service",
  "title": "Notification Service",
  "tags": [
    "kinetix",
    "notification-service",
    "overview"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "links": [
    { "title": "Service Overview", "type": "link", "url": "/d/kinetix-service-overview", "icon": "dashboard" },
    { "title": "System Health", "type": "link", "url": "/d/kinetix-system-health", "icon": "dashboard" },
    { "title": "Service Logs", "type": "link", "url": "/d/kinetix-service-logs", "icon": "dashboard" }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Data source",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "regex": "",
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "In-App Delivery Rate",
      "type": "stat",
      "description": "Rate of alert events successfully delivered in-app (persisted for the UI to poll back). Owner: notification-service, InAppDeliveryService.deliver().",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(notification_inapp_messages_delivered_total{job=\"notification-service\"}[5m]))",
          "legendFormat": "Delivered/s",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "No data",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 2,
      "title": "In-App Delivery Failure Rate",
      "type": "stat",
      "description": "Rate of in-app delivery failures — a non-zero value means alerts are not reaching the UI.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(notification_inapp_delivery_failures_total{job=\"notification-service\"}[5m]))",
          "legendFormat": "Failures/s",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "No data",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "links": [
        {
          "title": "View Logs",
          "type": "link",
          "url": "/d/kinetix-service-logs?from=${__from}&to=${__to}",
          "targetBlank": false
        }
      ]
    },
    {
      "id": 3,
      "title": "In-App Delivery Success Rate",
      "type": "gauge",
      "description": "Share of in-app delivery attempts that succeeded over the last 5m. 100% when no failures have occurred.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(notification_inapp_messages_delivered_total{job=\"notification-service\"}[5m])) / clamp_min(sum(rate(notification_inapp_messages_delivered_total{job=\"notification-service\"}[5m])) + sum(rate(notification_inapp_delivery_failures_total{job=\"notification-service\"}[5m])), 1)",
          "legendFormat": "Success rate",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "No data",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 4,
      "title": "Total In-App Messages Delivered",
      "type": "stat",
      "description": "Cumulative count of alert events delivered in-app since process start.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(notification_inapp_messages_delivered_total{job=\"notification-service\"})",
          "legendFormat": "Delivered",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "No data",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 5,
      "title": "In-App Delivery Rate by Severity",
      "type": "timeseries",
      "description": "In-app delivery rate split by alert severity (INFO / WARNING / CRITICAL).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (severity) (rate(notification_inapp_messages_delivered_total{job=\"notification-service\"}[5m]))",
          "legendFormat": "{{severity}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "No data"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "In-App Delivery Failure Rate by Severity",
      "type": "timeseries",
      "description": "In-app delivery failure rate split by alert severity. A persistent series here means alerts of that severity are not reaching the UI.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum by (severity) (rate(notification_inapp_delivery_failures_total{job=\"notification-service\"}[5m]))",
          "legendFormat": "{{severity}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "No data"
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Cumulative In-App Deliveries by Severity",
      "type": "timeseries",
      "description": "Running total of in-app deliveries by severity, plus cumulative delivery failures.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (severity) (notification_inapp_messages_delivered_total{job=\"notification-service\"})",
          "legendFormat": "delivered {{severity}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "sum(notification_inapp_delivery_failures_total{job=\"notification-service\"})",
          "legendFormat": "failures (total)",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "No data"
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "HTTP Request Rate by Route",
      "type": "timeseries",
      "description": "Ktor server request rate for the notification-service API routes (alert rules and alert lifecycle endpoints).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum by (route) (rate(ktor_http_server_requests_seconds_count{job=\"notification-service\"}[5m]))",
          "legendFormat": "{{route}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "noValue": "No data"
        },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
