{
  "uid": "kinetix-gateway",
  "title": "API Gateway",
  "tags": [
    "kinetix",
    "gateway",
    "overview"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "links": [
    { "title": "Service Overview", "type": "link", "url": "/d/kinetix-service-overview", "icon": "dashboard" },
    { "title": "System Health", "type": "link", "url": "/d/kinetix-system-health", "icon": "dashboard" },
    { "title": "Service Logs", "type": "link", "url": "/d/kinetix-service-logs", "icon": "dashboard" }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Data source",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "regex": "",
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Request Rate",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(ktor_http_server_requests_seconds_count{job=\"gateway\"}[5m]))",
          "legendFormat": "Requests/s",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "noValue": "No data",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 2,
      "title": "5xx Error Ratio",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "(sum(rate(ktor_http_server_requests_seconds_count{job=\"gateway\", status=~\"5..\"}[5m])) or vector(0)) / clamp_min(sum(rate(ktor_http_server_requests_seconds_count{job=\"gateway\"}[5m])), 1)",
          "legendFormat": "5xx ratio",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "No data",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "links": [
        {
          "title": "View Logs",
          "type": "link",
          "url": "/d/kinetix-service-logs?from=${__from}&to=${__to}",
          "targetBlank": false
        }
      ]
    },
    {
      "id": 3,
      "title": "In-Flight Requests",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(ktor_http_server_requests_active{job=\"gateway\"})",
          "legendFormat": "Active requests",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "No data",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 4,
      "title": "Max P95 Latency",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "max(histogram_quantile(0.95, sum by (le, route) (rate(ktor_http_server_requests_seconds_bucket{job=\"gateway\"}[5m]))))",
          "legendFormat": "Max P95",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "noValue": "No data",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 5,
      "title": "Request Rate by Route",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (route) (rate(ktor_http_server_requests_seconds_count{job=\"gateway\"}[5m]))",
          "legendFormat": "{{route}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "4xx / 5xx Error Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(ktor_http_server_requests_seconds_count{job=\"gateway\", status=~\"4..\"}[5m]))",
          "legendFormat": "4xx",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "sum(rate(ktor_http_server_requests_seconds_count{job=\"gateway\", status=~\"5..\"}[5m]))",
          "legendFormat": "5xx",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Latency Percentiles by Route (P95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, route) (rate(ktor_http_server_requests_seconds_bucket{job=\"gateway\"}[5m])))",
          "legendFormat": "p50 {{route}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(ktor_http_server_requests_seconds_bucket{job=\"gateway\"}[5m])))",
          "legendFormat": "p95 {{route}}",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, route) (rate(ktor_http_server_requests_seconds_bucket{job=\"gateway\"}[5m])))",
          "legendFormat": "p99 {{route}}",
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "Upstream Service-Call Latency (P95 by proxied route)",
      "type": "timeseries",
      "description": "The gateway's CIO HTTP client emits no client-side metrics, so upstream latency is derived from the gateway's own per-route P95 server latency. Each /api/* route proxies one upstream Kinetix service, so this is a close proxy for upstream call time plus gateway overhead.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(ktor_http_server_requests_seconds_bucket{job=\"gateway\", route=~\"/api/.*\"}[5m])))",
          "legendFormat": "{{route}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "id": 9,
      "title": "In-Flight Requests Over Time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum(ktor_http_server_requests_active{job=\"gateway\"})",
          "legendFormat": "Active requests",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
