{
  "uid": "kinetix-risk-engine",
  "title": "Risk Engine",
  "tags": ["kinetix", "risk"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    { "title": "System Health", "type": "link", "url": "/d/kinetix-system-health", "icon": "dashboard" },
    { "title": "Service Overview", "type": "link", "url": "/d/kinetix-service-overview", "icon": "dashboard" },
    { "title": "Trade Flow", "type": "link", "url": "/d/kinetix-trade-flow", "icon": "dashboard" },
    { "title": "Risk Overview — Business & Limits", "type": "link", "url": "/d/kinetix-risk-overview?var-book_id=${book_id}", "icon": "dashboard", "tooltip": "Business/limit view: current VaR, Expected Shortfall and component breakdown per book. This dashboard (Risk Engine) is the engine-throughput view." },
    { "title": "Risk Orchestrator", "type": "link", "url": "/d/kinetix-risk-orchestrator?var-book_id=${book_id}", "icon": "dashboard" },
    { "title": "Price", "type": "link", "url": "/d/kinetix-prices", "icon": "dashboard" },
    { "title": "Kafka Health", "type": "link", "url": "/d/kinetix-kafka-health", "icon": "dashboard" },
    { "title": "Database Health", "type": "link", "url": "/d/kinetix-database-health", "icon": "dashboard" },
    { "title": "Service Logs", "type": "link", "url": "/d/kinetix-service-logs", "icon": "dashboard" }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Data source",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "regex": "",
        "options": []
      },
      {
        "name": "book_id",
        "type": "query",
        "label": "Book",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(risk_var_value, book_id)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" },
        "multi": true,
        "sort": 1
      },
      {
        "name": "calculation_type",
        "type": "query",
        "label": "Method",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(risk_var_value, calculation_type)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1
      },
      {
        "name": "confidence_level",
        "type": "query",
        "label": "Confidence",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(risk_var_value, confidence_level)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "title": "VaR Calculation Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(risk_var_calculation_total[5m])",
          "legendFormat": "{{calculation_type}} @ {{confidence_level}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "title": "VaR Calculation Duration (P95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(risk_var_calculation_duration_seconds_bucket[5m]))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.50, rate(risk_var_calculation_duration_seconds_bucket[5m]))",
          "legendFormat": "P50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "title": "Current VaR by Portfolio ($confidence_level confidence, 1-day)",
      "description": "Value at Risk per book at the selected confidence level over a 1-day holding period (engine default — VaRCalculationRequest.timeHorizonDays = 1). Cumulative point-in-time figure: the latest VaR reported by the engine.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "risk_var_value{book_id=~\"$book_id\", calculation_type=\"$calculation_type\", confidence_level=\"$confidence_level\"}",
          "legendFormat": "{{book_id}} — VaR {{confidence_level}}, 1-day"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "noValue": "No data"
        },
        "overrides": []
      }
    },
    {
      "title": "Expected Shortfall / CVaR ($confidence_level confidence, 1-day)",
      "description": "Expected Shortfall (Conditional VaR): the mean loss in the tail beyond the VaR threshold, at the selected confidence level over a 1-day holding period. Cumulative point-in-time figure from the latest engine calculation.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "risk_var_expected_shortfall{book_id=~\"$book_id\", calculation_type=\"$calculation_type\", confidence_level=\"$confidence_level\"}",
          "legendFormat": "{{book_id}} — ES {{confidence_level}}, 1-day"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "noValue": "No data"
        },
        "overrides": []
      }
    },
    {
      "title": "VaR Component Contribution (1-day)",
      "description": "Component contribution to 1-day Value at Risk, decomposed by asset class. Cumulative point-in-time figure from the latest VaR calculation; per-asset-class contributions sum to total portfolio VaR.",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "risk_var_component_contribution{book_id=~\"$book_id\"}",
          "legendFormat": "{{book_id}} / {{asset_class}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "noValue": "No data"
        },
        "overrides": []
      }
    },
    {
      "title": "Greeks Calculation Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "rate(greeks_calculation_total[5m])",
          "legendFormat": "Greeks/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "title": "Greeks Calculation Duration (P95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(greeks_calculation_duration_seconds_bucket[5m]))",
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "title": "Stress Test Rate & Duration",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(stress_test_total[5m])",
          "legendFormat": "{{scenario_name}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, rate(stress_test_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 Duration"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p95 Duration" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.axisLabel", "value": "Duration" }
            ]
          }
        ]
      }
    },
    {
      "title": "FRTB Calculation Rate & Duration",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(frtb_calculation_total[5m])",
          "legendFormat": "FRTB/s"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, rate(frtb_calculation_duration_seconds_bucket[5m]))",
          "legendFormat": "P95 Duration"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "P95 Duration" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.axisLabel", "value": "Duration" }
            ]
          }
        ]
      }
    },
    {
      "title": "ML Predictions",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "rate(ml_prediction_total[5m])",
          "legendFormat": "{{model_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "title": "Anomalies Detected",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "rate(ml_anomaly_detected_total[5m])",
          "legendFormat": "{{metric_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  }
}
