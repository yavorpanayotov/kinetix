{
  "uid": "kinetix-risk-overview",
  "title": "Risk Overview",
  "tags": [
    "kinetix",
    "risk"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "links": [
    { "title": "System Health", "type": "link", "url": "/d/kinetix-system-health", "icon": "dashboard" },
    { "title": "Service Overview", "type": "link", "url": "/d/kinetix-service-overview", "icon": "dashboard" },
    { "title": "Trade Flow", "type": "link", "url": "/d/kinetix-trade-flow", "icon": "dashboard" },
    { "title": "Risk Engine — Throughput & Performance", "type": "link", "url": "/d/kinetix-risk-engine?var-book_id=${book_id}", "icon": "dashboard", "tooltip": "Engine-throughput view: VaR/Greeks calculation rate, latency and stress-test performance. This dashboard (Risk Overview) is the business/limit view." },
    { "title": "Risk Orchestrator", "type": "link", "url": "/d/kinetix-risk-orchestrator?var-book_id=${book_id}", "icon": "dashboard" },
    { "title": "Price", "type": "link", "url": "/d/kinetix-prices", "icon": "dashboard" },
    { "title": "Kafka Health", "type": "link", "url": "/d/kinetix-kafka-health", "icon": "dashboard" },
    { "title": "Database Health", "type": "link", "url": "/d/kinetix-database-health", "icon": "dashboard" },
    { "title": "Service Logs", "type": "link", "url": "/d/kinetix-service-logs", "icon": "dashboard" }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Data source",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "regex": "",
        "options": []
      },
      {
        "name": "book_id",
        "type": "query",
        "label": "Book",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(risk_var_value, book_id)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" },
        "multi": true,
        "sort": 1
      },
      {
        "name": "calculation_type",
        "type": "query",
        "label": "Method",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(risk_var_value, calculation_type)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1
      },
      {
        "name": "confidence_level",
        "type": "query",
        "label": "Confidence",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(risk_var_value, confidence_level)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Current VaR ($confidence_level confidence, 1-day)",
      "description": "Value at Risk at the selected confidence level over a 1-day holding period (the engine default — VaRCalculationRequest.timeHorizonDays = 1). Confidence level and method follow the dashboard's Confidence and Method variables. Cumulative point-in-time figure: the latest VaR reported by the engine, not an interval aggregate.",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "risk_var_value{book_id=~\"$book_id\", calculation_type=\"$calculation_type\", confidence_level=\"$confidence_level\"}",
          "legendFormat": "{{book_id}} — VaR {{confidence_level}}, 1-day ({{calculation_type}})",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500000
              },
              {
                "color": "red",
                "value": 1000000
              }
            ]
          },
          "unit": "currencyUSD",
          "noValue": "No data"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      }
    },
    {
      "id": 2,
      "title": "VaR Trend ($confidence_level confidence, 1-day)",
      "description": "Trend of 1-day Value at Risk at the selected confidence level over the dashboard time window. Each point is the engine's point-in-time VaR for that instant — the series is a history of cumulative VaR snapshots, not an interval-summed value.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "risk_var_value{book_id=~\"$book_id\", calculation_type=\"$calculation_type\", confidence_level=\"$confidence_level\"}",
          "legendFormat": "{{book_id}} — VaR {{confidence_level}}, 1-day",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      }
    },
    {
      "id": 3,
      "title": "Expected Shortfall / CVaR ($confidence_level confidence, 1-day)",
      "description": "Expected Shortfall (Conditional VaR): the mean loss in the tail beyond the VaR threshold, at the selected confidence level over a 1-day holding period. Cumulative point-in-time figure — the latest value reported by the engine, not an interval aggregate.",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "risk_var_expected_shortfall{book_id=~\"$book_id\", calculation_type=\"$calculation_type\", confidence_level=\"$confidence_level\"}",
          "legendFormat": "{{book_id}} — ES {{confidence_level}}, 1-day",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "noValue": "No data"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      }
    },
    {
      "id": 4,
      "title": "VaR Component Breakdown (1-day)",
      "description": "Component contribution to 1-day Value at Risk, decomposed by asset class. Cumulative point-in-time figure from the latest VaR calculation. Component contributions sum to total portfolio VaR; per-asset-class contributions can be negative where a position diversifies portfolio risk.",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "risk_var_component_contribution{book_id=~\"$book_id\"}",
          "legendFormat": "{{book_id}} / {{asset_class}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      }
    },
    {
      "id": 5,
      "title": "VaR Calculation Count",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(rate(risk_var_calculation_total[5m]))",
          "legendFormat": "Calculations/s",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "noValue": "No data"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
