{
  "uid": "kinetix-fix-gateway-canary",
  "title": "FIX Gateway — Canary SLI Dashboard",
  "description": "Three SLI panels that gate the fix-gateway phase-4 canary rollout: order rejection rate (< 0.5%), FIX session uptime (> 99.5%), and average ack latency (< 250 ms). All three must remain within threshold for 5 consecutive minutes before the CanaryGate emits decision=Allowed and the operator may advance FIX_GATEWAY_PLACE_ORDER.",
  "tags": ["kinetix", "fix-gateway", "canary", "sli"],
  "timezone": "browser",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "links": [
    { "title": "Trade Lifecycle", "type": "link", "url": "/d/kinetix-trade-lifecycle", "icon": "dashboard" },
    { "title": "Risk Run Health", "type": "link", "url": "/d/kinetix-risk-run-health", "icon": "dashboard" }
  ],
  "templating": {
    "list": [
      {
        "name": "venue",
        "type": "query",
        "label": "Venue",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(fix_messages_out_total, venue)",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "multi": false,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Order Rejection Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Order rejection rate as a percentage of all outbound order attempts (cancel_failed_total / (fix_messages_out_total + cancel_failed_total)). Must stay below 0.5% for canary promotion.",
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(cancel_failed_total{venue=~\"$venue\"}[5m])) / (sum(rate(fix_messages_out_total{venue=~\"$venue\"}[5m])) + sum(rate(cancel_failed_total{venue=~\"$venue\"}[5m])))",
          "legendFormat": "Rejection rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          }
        }
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "alert": {
        "name": "Order rejection rate breaches canary threshold",
        "conditions": [
          {
            "evaluator": { "params": [0.5], "type": "gt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "avg" },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "noDataState": "no_data",
        "for": "5m"
      }
    },
    {
      "id": 2,
      "title": "FIX Session Uptime",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "FIX session availability expressed as a percentage: 100% minus the fraction of outbound attempts that returned SESSION_DOWN. Must stay above 99.5% for canary promotion.",
      "targets": [
        {
          "refId": "A",
          "expr": "100 - (100 * sum(rate(cancel_failed_total{venue=~\"$venue\",reason=\"SESSION_DOWN\"}[5m])) / (sum(rate(fix_messages_out_total{venue=~\"$venue\"}[5m])) + sum(rate(cancel_failed_total{venue=~\"$venue\"}[5m]))))",
          "legendFormat": "Session uptime %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 95,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99.0 },
              { "color": "green", "value": 99.5 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          }
        }
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "alert": {
        "name": "FIX session uptime breaches canary threshold",
        "conditions": [
          {
            "evaluator": { "params": [99.5], "type": "lt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "avg" },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "noDataState": "no_data",
        "for": "5m"
      }
    },
    {
      "id": 3,
      "title": "Avg Cancel-Ack Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Average cancel-acknowledgement latency derived from the cancel_ack_latency_seconds histogram. Must stay below 250 ms for canary promotion.",
      "targets": [
        {
          "refId": "A",
          "expr": "1000 * sum(rate(cancel_ack_latency_seconds_sum{venue=~\"$venue\"}[5m])) / sum(rate(cancel_ack_latency_seconds_count{venue=~\"$venue\"}[5m]))",
          "legendFormat": "Avg ack latency ms"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 250 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          }
        }
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "alert": {
        "name": "Avg cancel-ack latency breaches canary threshold",
        "conditions": [
          {
            "evaluator": { "params": [250], "type": "gt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "avg" },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "noDataState": "no_data",
        "for": "5m"
      }
    },
    {
      "id": 4,
      "title": "Outbound FIX Messages — Rate",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Rate of outbound FIX messages per second broken down by message type. Healthy baseline for the rejection-rate and latency panels above.",
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (msg_type) (rate(fix_messages_out_total{venue=~\"$venue\"}[5m]))",
          "legendFormat": "{{msg_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": { "lineWidth": 1, "fillOpacity": 5 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 5,
      "title": "Cancel Failures by Reason",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Rate of cancel failures broken down by reason (SESSION_DOWN, UNKNOWN_VENUE, INVALID_REQUEST). Feeds directly into the rejection-rate and uptime SLI calculations above.",
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (reason) (rate(cancel_failed_total{venue=~\"$venue\"}[5m]))",
          "legendFormat": "{{reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": { "lineWidth": 1, "fillOpacity": 5 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 6,
      "title": "Ack Latency Histogram (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Percentile breakdown of cancel-acknowledgement latency. The 250 ms canary threshold applies to the average; p99 reveals tail behaviour and likely causes of batch degradation.",
      "targets": [
        {
          "refId": "A",
          "expr": "1000 * histogram_quantile(0.50, sum by (le) (rate(cancel_ack_latency_seconds_bucket{venue=~\"$venue\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "1000 * histogram_quantile(0.95, sum by (le) (rate(cancel_ack_latency_seconds_bucket{venue=~\"$venue\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "1000 * histogram_quantile(0.99, sum by (le) (rate(cancel_ack_latency_seconds_bucket{venue=~\"$venue\"}[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 250 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 7,
      "title": "Unacknowledged Outbound Orders",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Gauge of outbound 35=D NewOrderSingle messages currently awaiting a venue acknowledgement. A sustained non-zero value with low throughput is a leading indicator of session degradation.",
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (venue) (unacknowledged_outbound{venue=~\"$venue\"})",
          "legendFormat": "{{venue}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }
  ],
  "schemaVersion": 38
}
