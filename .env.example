# Kinetix environment variable reference.
# Copy to .env and adjust values for local development. Service-specific
# variables are grouped per service below.

# ai-insights-service
# DEMO_MODE=true uses the canned in-process narratives; unset/false uses the
# Claude Agent SDK with the host's authenticated `claude` CLI.
DEMO_MODE=false
# CLAUDE_HOME points the Agent SDK at a non-default Claude config directory.
# Leave unset for the default (~/.claude).
# CLAUDE_HOME=/root/.claude
